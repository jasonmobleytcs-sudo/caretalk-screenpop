{
  "manifest_version": 3,
  "name": "CareTalk360 Screenpop",
  "version": "2.0",
  "description": "Automatically opens CareTalk360 in Chrome when a Zoom CC call transfer arrives.",
  "permissions": ["tabs", "alarms", "storage"],
  "host_permissions": ["https://caretalk-screenpop.onrender.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "CareTalk Screenpop"
  }
}
